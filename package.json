{
  "name": "autoshop-manager",
  "version": "1.0.0",
  "description": "AutoShop inventory and repair system",
  "author": "Dakota Switzer",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd frontend && npm install && npm run build",
    "build-backend": "cd backend && npm install",
    "build": "npm run build-frontend && npm run build-backend && electron-builder --win",
    "publish": "npm run build-frontend && npm run build-backend && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.autoshop.manager",
    "productName": "AutoShop Manager",
    "artifactName": "AutoShop-Manager-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutoShop Manager"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dakota158",
        "repo": "NPRAFS_Service_Center"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}