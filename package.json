{
  "name": "autoshop-manager",
  "version": "1.0.0",
  "description": "AutoShop inventory and repair system",
  "author": "Dakota Switzer",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build-frontend && electron-builder --win",
    "publish": "npm run build-frontend && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.autoshop.manager",
    "productName": "AutoShop Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dakota158",
        "repo": "NPRAFS-Service-Center"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}