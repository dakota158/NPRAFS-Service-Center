{
  "name": "nprafs-service-center",
  "version": "1.0.0",
  "description": "NPRAFS Service Center inventory and repair system",
  "author": "Dakota Switzer",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd frontend && npm install && npm run build",
    "build-backend": "cd backend && npm install",
    "build": "npm run build-frontend && npm run build-backend && electron-builder --win",
    "publish": "npm run build-frontend && npm run build-backend && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.nprafs.servicecenter",
    "productName": "NPRAFS Service Center",
    "artifactName": "NPRAFS-Service-Center-Setup-${version}.${ext}",
    "copyright": "Copyright © 2026 NPRAFS Service Center",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "frontend/public/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NPRAFS Service Center",
      "artifactName": "NPRAFS-Service-Center-Setup-${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "installerHeader": "build/installer-header.bmp",
      "uninstallDisplayName": "NPRAFS Service Center",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dakota158",
        "repo": "NPRAFS_Service_Center"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}